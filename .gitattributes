# Normalize text files in this repository.
# Markdown and common documentation/source files should use Windows CRLF line endings
# in the working tree.

*.md text eol=crlf
*.txt text eol=crlf
*.html text eol=crlf
*.css text eol=crlf
*.js text eol=crlf
*.json text eol=crlf
*.xml text eol=crlf
*.yml text eol=crlf
*.yaml text eol=crlf

# Treat common binary/image/media/archive files as binary.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mp3 binary
*.mp4 binary
*.pdf binary
*.zip binary

# SVG is XML/text, so keep it normalized as text.
*.svg text eol=crlf
